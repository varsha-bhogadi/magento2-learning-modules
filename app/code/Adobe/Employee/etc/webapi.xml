<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Webapi:etc/webapi.xsd">

    <!-- GET employee -->
    <route url="/V1/employee/:entityId" method="GET">
        <service class="Adobe\Employee\Api\EmployeeRepositoryInterface" method="getById"/>
        <resources>
            <resource ref="anonymous"/>
        </resources>
    </route>

    <!-- CREATE employee -->
    <route url="/V1/employee" method="POST">
        <service class="Adobe\Employee\Api\EmployeeRepositoryInterface" method="save"/>
        <resources>
            <resource ref="anonymous"/>
        </resources>
    </route>

    <!-- UPDATE employee -->
    <route url="/V1/employee/:entityId" method="PUT">
        <service class="Adobe\Employee\Api\EmployeeRepositoryInterface" method="update"/>
        <resources>
            <resource ref="anonymous"/>
        </resources>
    </route>

    <!-- DELETE employee -->
    <route url="/V1/employee/:entityId" method="DELETE">
        <service class="Adobe\Employee\Api\EmployeeRepositoryInterface" method="deleteById"/>
        <resources>
            <resource ref="anonymous"/>
        </resources>
    </route>

</routes>