type Employee {
    id: Int
    name: String
    gender: String
    designation: String
    joining_date: String
    address: String
    status: Int
    hobbies: String
}

type Query {
    employee(id: Int!): Employee
        @resolver(class: "Adobe\\Employee\\Model\\Resolver\\EmployeeById")

    employees: [Employee]
        @resolver(class: "Adobe\\Employee\\Model\\Resolver\\EmployeeList")
}

type Mutation {
    createEmployee(
        name: String!,
        gender: String,
        designation: String,
        joining_date: String,
        address: String,
        status: Int,
        hobbies: String
    ): Employee
        @resolver(class: "Adobe\\Employee\\Model\\Resolver\\CreateEmployee")

    updateEmployee(
        id: Int!,
        name: String,
        gender: String,
        designation: String,
        joining_date: String,
        address: String,
        status: Int,
        hobbies: String
    ): Employee
        @resolver(class: "Adobe\\Employee\\Model\\Resolver\\UpdateEmployee")

    deleteEmployee(id: Int!): Boolean
        @resolver(class: "Adobe\\Employee\\Model\\Resolver\\DeleteEmployee")
}