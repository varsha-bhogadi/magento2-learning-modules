<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="customer_account_navigation">

            <block class="Magento\Framework\View\Element\Html\Link\Current"
                   name="customer-account-navigation-employee">
                <arguments>
                    <argument name="label" xsi:type="string">Employee</argument>
                    <argument name="path" xsi:type="string">employee/account/index</argument>
                </arguments>
            </block>

            <block class="Magento\Framework\View\Element\Html\Link\Current"
                   name="customer-account-navigation-koemployee">
                <arguments>
                    <argument name="label" xsi:type="string">KOEmployee</argument>
                    <argument name="path" xsi:type="string">employee/ko/index</argument>
                </arguments>
            </block>

        </referenceBlock>
    </body>
</page>