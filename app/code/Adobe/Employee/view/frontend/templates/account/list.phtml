/** @var \Adobe\Employee\Block\Account\EmployeeList $block */
/** @var \Magento\Framework\Escaper $escaper */

$employees = $block->getEmployees();
?>

<div class="employee-account-wrapper">

    <div class="page-title-wrapper">
        <h1 class="page-title">
            <span><?= $escaper->escapeHtml(__('My Employees')) ?></span>
        </h1>

        <div class="actions-toolbar">
            <div class="primary">
                <a class="action primary add"
                   href="<?= $escaper->escapeUrl(
                       $block->getUrl('employee/account/create')
                   ) ?>">
                    <span><?= $escaper->escapeHtml(__('Add Employee')) ?></span>
                </a>
            </div>
        </div>
    </div>

    <?php if ($employees && $employees->getSize()): ?>
        <div class="table-wrapper employee-table">
            <table class="data table table-order-items history">
                <thead>
                <tr>
                    <th><?= $escaper->escapeHtml(__('ID')) ?></th>
                    <th><?= $escaper->escapeHtml(__('Name')) ?></th>
                    <th><?= $escaper->escapeHtml(__('Designation')) ?></th>
                    <th><?= $escaper->escapeHtml(__('Address')) ?></th>
                    <th><?= $escaper->escapeHtml(__('Status')) ?></th>
                    <th><?= $escaper->escapeHtml(__('Hobbies')) ?></th>
                    <th><?= $escaper->escapeHtml(__('Actions')) ?></th>
                </tr>
                </thead>

                <tbody>
                <?php foreach ($employees as $employee): ?>
                    <tr>
                        <td><?= (int) $employee->getId() ?></td>

                        <td><?= $escaper->escapeHtml(
                            $employee->getName()
                        ) ?></td>

                        <td><?= $escaper->escapeHtml(
                            $employee->getDesignation()
                        ) ?></td>

                        <td><?= $escaper->escapeHtml(
                            $employee->getAddress()
                        ) ?></td>

                        <td>
                            <?= $employee->getStatus()
                                ? $escaper->escapeHtml(__('Enabled'))
                                : $escaper->escapeHtml(__('Disabled')) ?>
                        </td>

                        <td><?= $escaper->escapeHtml(
                            $employee->getHobbies()
                        ) ?></td>

                        <td class="actions">
                            <a href="<?= $escaper->escapeUrl(
                                $block->getUrl(
                                    'employee/account/edit',
                                    ['id' => $employee->getId()]
                                )
                            ) ?>">
                                <?= $escaper->escapeHtml(__('Edit')) ?>
                            </a>

                            &nbsp;|&nbsp;

                            <a href="<?= $escaper->escapeUrl(
                                $block->getUrl(
                                    'employee/account/delete',
                                    ['id' => $employee->getId()]
                                )
                            ) ?>"
                               onclick="return confirm(
                                   'Are you sure you want to delete this employee?'
                               )">
                                <?= $escaper->escapeHtml(__('Delete')) ?>
                            </a>
                        </td>
                    </tr>
                <?php endforeach; ?>
                </tbody>

            </table>
        </div>
    <?php else: ?>
        <div class="message info empty">
            <span><?= $escaper->escapeHtml(__('No employees found.')) ?></span>
        </div>
    <?php endif; ?>

</div>