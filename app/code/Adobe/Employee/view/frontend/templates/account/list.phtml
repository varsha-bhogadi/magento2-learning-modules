/** @var \Adobe\Employee\Block\Account\EmployeeList $block */

$employees = $block->getEmployees();
?>

<div class="employee-account-wrapper">

    <div class="page-title-wrapper">
        <h1 class="page-title">
            <span><?= $block->escapeHtml(__('My Employees')) ?></span>
        </h1>

        <div class="actions-toolbar">
            <div class="primary">
                <a class="action primary add"
                   href="<?= $block->escapeUrl($block->getUrl('employee/account/create')) ?>">
                    <span><?= $block->escapeHtml(__('Add Employee')) ?></span>
                </a>
            </div>
        </div>
    </div>

    <?php if ($employees && $employees->getSize()): ?>
        <div class="table-wrapper employee-table">

            <table class="data table table-order-items history">

                <thead>
                <tr>
                    <th><?= $block->escapeHtml(__('ID')) ?></th>
                    <th><?= $block->escapeHtml(__('Name')) ?></th>
                    <th><?= $block->escapeHtml(__('Designation')) ?></th>
                    <th><?= $block->escapeHtml(__('Address')) ?></th>
                    <th><?= $block->escapeHtml(__('Status')) ?></th>
                    <th><?= $block->escapeHtml(__('Hobbies')) ?></th>
                    <th><?= $block->escapeHtml(__('Actions')) ?></th>
                </tr>
                </thead>

                <tbody>
                <?php foreach ($employees as $employee): ?>

                    <?php
                    $hobbies = $employee->getHobbies();
                    $hobbyList = $hobbies ? explode(',', $hobbies) : [];
                    ?>

                    <tr>
                        <td><?= (int)$employee->getId() ?></td>

                        <td><?= $block->escapeHtml($employee->getName()) ?></td>

                        <td><?= $block->escapeHtml($employee->getDesignation()) ?></td>

                        <td><?= $block->escapeHtml($employee->getAddress()) ?></td>

                        <td>
                            <?= (int)$employee->getStatus()
                                ? $block->escapeHtml(__('Enabled'))
                                : $block->escapeHtml(__('Disabled')) ?>
                        </td>

                        <td>
                            <?= $block->escapeHtml(implode(', ', $hobbyList)) ?>
                        </td>

                        <td class="actions">

                            <!-- EDIT -->
                            <a href="<?= $block->escapeUrl(
                                $block->getUrl('employee/account/edit', ['id' => $employee->getId()])
                            ) ?>">
                                <?= $block->escapeHtml(__('Edit')) ?>
                            </a>

                            <!-- DELETE -->
                            <a href="<?= $block->escapeUrl(
                                $block->getUrl('employee/account/delete', ['id' => $employee->getId()])
                            ) ?>"
                               onclick="return confirm('Are you sure you want to delete this employee?')">
                                <?= $block->escapeHtml(__('Delete')) ?>
                            </a>

                        </td>
                    </tr>

                <?php endforeach; ?>
                </tbody>

            </table>

        </div>

    <?php else: ?>
        <div class="message info empty">
            <span><?= $block->escapeHtml(__('No employees found.')) ?></span>
        </div>
    <?php endif; ?>

</div>