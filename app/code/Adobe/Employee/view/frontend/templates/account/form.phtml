/** @var \Adobe\Employee\Block\Account\EmployeeForm $block */

$employee = $block->getCurrentEmployee();
$hobbies = [];

if ($employee && $employee->getHobbies()) {
    $hobbies = explode(',', (string)$employee->getHobbies());
}
?>

<form action="<?= $escaper->escapeUrl($block->getSaveUrl()) ?>"
      method="post"
      id="employee-form">

    <?= $block->getBlockHtml('formkey') ?>

    <input type="hidden"
           name="entity_id"
           value="<?= $employee ? (int)$employee->getId() : '' ?>" />

    <fieldset class="fieldset">

        <!-- NAME -->
        <div class="field required">
            <label><?= $escaper->escapeHtml(__('Name')) ?></label>
            <input type="text"
                   name="name"
                   value="<?= $employee ? $escaper->escapeHtml($employee->getName()) : '' ?>"
                   required />
        </div>

        <!-- GENDER -->
        <div class="field required">
            <label><?= $escaper->escapeHtml(__('Gender')) ?></label><br/>

            <label>
                <input type="radio"
                       name="gender"
                       value="Male"
                    <?= ($employee && $employee->getGender() === 'Male') ? 'checked' : '' ?> />
                <?= $escaper->escapeHtml(__('Male')) ?>
            </label>

            <label style="margin-left:15px;">
                <input type="radio"
                       name="gender"
                       value="Female"
                    <?= ($employee && $employee->getGender() === 'Female') ? 'checked' : '' ?> />
                <?= $escaper->escapeHtml(__('Female')) ?>
            </label>
        </div>

        <!-- DESIGNATION -->
        <div class="field required">
            <label><?= $escaper->escapeHtml(__('Designation')) ?></label>
            <input type="text"
                   name="designation"
                   value="<?= $employee ? $escaper->escapeHtml($employee->getDesignation()) : '' ?>"
                   required />
        </div>

        <!-- JOINING DATE -->
        <div class="field required">
            <label><?= $escaper->escapeHtml(__('Joining Date')) ?></label>
            <input type="date"
                   name="joining_date"
                   value="<?= $employee ? $escaper->escapeHtml($employee->getJoiningDate()) : '' ?>"
                   required />
        </div>

        <!-- ADDRESS -->
        <div class="field">
            <label><?= $escaper->escapeHtml(__('Address')) ?></label>
            <textarea name="address"><?= $employee ? $escaper->escapeHtml($employee->getAddress()) : '' ?></textarea>
        </div>

        <!-- STATUS -->
        <div class="field">
            <label><?= $escaper->escapeHtml(__('Status')) ?></label>
            <select name="status">
                <option value="1"
                    <?= ($employee && (int)$employee->getStatus() === 1) ? 'selected' : '' ?>>
                    <?= $escaper->escapeHtml(__('Enabled')) ?>
                </option>

                <option value="0"
                    <?= ($employee && (int)$employee->getStatus() === 0) ? 'selected' : '' ?>>
                    <?= $escaper->escapeHtml(__('Disabled')) ?>
                </option>
            </select>
        </div>

        <!-- HOBBIES -->
        <div class="field">
            <label><?= $escaper->escapeHtml(__('Hobbies')) ?></label><br/>

            <label>
                <input type="checkbox"
                       name="hobbies[]"
                       value="Reading"
                    <?= in_array('Reading', $hobbies) ? 'checked' : '' ?> />
                <?= $escaper->escapeHtml(__('Reading')) ?>
            </label>

            <label style="margin-left:15px;">
                <input type="checkbox"
                       name="hobbies[]"
                       value="Sports"
                    <?= in_array('Sports', $hobbies) ? 'checked' : '' ?> />
                <?= $escaper->escapeHtml(__('Sports')) ?>
            </label>

            <label style="margin-left:15px;">
                <input type="checkbox"
                       name="hobbies[]"
                       value="Music"
                    <?= in_array('Music', $hobbies) ? 'checked' : '' ?> />
                <?= $escaper->escapeHtml(__('Music')) ?>
            </label>

            <label style="margin-left:15px;">
                <input type="checkbox"
                       name="hobbies[]"
                       value="Travel"
                    <?= in_array('Travel', $hobbies) ? 'checked' : '' ?> />
                <?= $escaper->escapeHtml(__('Travel')) ?>
            </label>
        </div>

    </fieldset>

    <div class="actions-toolbar">
        <button type="submit" class="action primary">
            <span><?= $escaper->escapeHtml(__('Save Employee')) ?></span>
        </button>
    </div>

</form>