<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">

    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">
                employee_form.employee_form_data_source
            </item>
        </item>
        <item name="label" xsi:type="string" translate="true">
            Employee Information
        </item>
        <item name="template" xsi:type="string">templates/form/collapsible</item>
    </argument>

    <settings>
        <buttons>
            <button name="back">
                <url path="*/*/"/>
                <class>back</class>
                <label translate="true">Back</label>
            </button>
            <button name="save">
                <url path="*/*/save"/>
                <class>save primary</class>
                <label translate="true">Save Employee</label>
            </button>
        </buttons>
        <namespace>employee_form</namespace>
        <dataScope>data</dataScope>
        <deps>
            <dep>employee_form.employee_form_data_source</dep>
        </deps>
    </settings>

    <dataSource name="employee_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">
                    Magento_Ui/js/form/provider
                </item>
            </item>
        </argument>
        <settings>
            <submitUrl path="*/*/save"/>
        </settings>
        <dataProvider
            class="Adobe\Employee\Ui\DataProvider\Employee\FormDataProvider"
            name="employee_form_data_source">
            <settings>
                <requestFieldName>entity_id</requestFieldName>
                <primaryFieldName>entity_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>

    <fieldset name="general">
        <settings>
            <label translate="true">Employee Details</label>
        </settings>

        <field name="entity_id" formElement="input">
            <settings>
                <dataType>text</dataType>
                <visible>false</visible>
            </settings>
        </field>

        <field name="name" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Name</label>
                <dataScope>name</dataScope>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>

        <field name="gender" formElement="select">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Gender</label>
                <dataScope>gender</dataScope>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options>
                            <option name="0" xsi:type="array">
                                <item name="value" xsi:type="string">male</item>
                                <item name="label" xsi:type="string" translate="true">
                                    Male
                                </item>
                            </option>
                            <option name="1" xsi:type="array">
                                <item name="value" xsi:type="string">female</item>
                                <item name="label" xsi:type="string" translate="true">
                                    Female
                                </item>
                            </option>
                        </options>
                    </settings>
                </select>
            </formElements>
        </field>

        <field name="designation" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Designation</label>
                <dataScope>designation</dataScope>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>

        <field name="joining_date" formElement="date">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Joining Date</label>
                <dataScope>joining_date</dataScope>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>

        <field name="address" formElement="textarea">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Address</label>
                <dataScope>address</dataScope>
            </settings>
        </field>

        <field name="hobbies" formElement="checkboxset">
            <settings>
                <dataType>array</dataType>
                <label translate="true">Hobbies</label>
                <dataScope>hobbies</dataScope>
            </settings>
            <formElements>
                <checkboxset>
                    <settings>
                    <options class="Adobe\Employee\Model\Source\Hobbies"/>
                    </settings>
                </checkboxset>
            </formElements>
        </field>

        <field name="status" formElement="select">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Status</label>
                <dataScope>status</dataScope>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="Adobe\Employee\Model\Source\Status"/>
                    </settings>
                </select>
            </formElements>
        </field>

    </fieldset>

</form>
